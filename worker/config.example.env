# Abstract mainnet public RPC
RPC_URL=https://api.mainnet.abs.xyz
# Supabase project (frontend reads these tables with the anon key)
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key
# Etherscan key (free tier) — enables auto-labeling of verified contracts
ETHERSCAN_API_KEY=
POLL_SECONDS=3
SYNC_MINUTES=10
DB_PATH=nexus.db
